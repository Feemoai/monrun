{
  "rules": {
    "devices": {
      "$deviceId": {

        // ── READ: Siapapun boleh baca data (dashboard publik) ──────
        ".read": true,

        // ── rooms: Hanya label/description/icon yang bisa diubah ──
        // Data sensor (latest, history, weather) TIDAK bisa diubah dari browser
        "rooms": {
          "$roomId": {
            ".write": "$roomId === 'A' || $roomId === 'B' || $roomId === 'C'",
            ".validate": "newData.hasChildren(['label', 'description', 'icon'])",

            "label": {
              ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 50"
            },
            "description": {
              ".validate": "newData.isString() && newData.val().length <= 100"
            },
            "icon": {
              ".validate": "newData.isString() && (newData.val() === 'school' || newData.val() === 'cpu' || newData.val() === 'flask')"
            }
          }
        },

        // ── Sensor data: hanya ESP32 yang boleh tulis ─────────────
        // Catatan: di production, gunakan Firebase Auth custom token untuk ESP32
        // sehingga bisa .write = "auth != null && auth.uid === 'esp32-device'"
        // Untuk sekarang: validasi struktur data saja

        "lastSeen": {
          ".write": true,
          ".validate": "newData.isNumber() && newData.val() > 0"
        },

        "battery": {
          ".write": true,
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100"
        },

        "latest": {
          ".write": true,
          ".validate": "newData.hasChildren(['room', 'temp', 'humidity', 'heatIndex', 'comfort', 'timestamp'])",

          "room":      { ".validate": "newData.isString() && (newData.val() === 'A' || newData.val() === 'B' || newData.val() === 'C')" },
          "temp":      { ".validate": "newData.isNumber() && newData.val() >= -40 && newData.val() <= 80" },
          "humidity":  { ".validate": "newData.isNumber() && newData.val() >= 0  && newData.val() <= 100" },
          "heatIndex": { ".validate": "newData.isNumber()" },
          "comfort":   { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 60" },
          "timestamp": { ".validate": "newData.isNumber() && newData.val() > 0" }
        },

        "history": {
          ".write": true,
          "$roomId": {
            ".indexOn": ["timestamp"],
            "$entryId": {
              ".validate": "newData.hasChildren(['room', 'temp', 'humidity', 'heatIndex', 'comfort', 'timestamp'])",

              "room":      { ".validate": "newData.isString() && (newData.val() === 'A' || newData.val() === 'B' || newData.val() === 'C')" },
              "temp":      { ".validate": "newData.isNumber() && newData.val() >= -40 && newData.val() <= 80" },
              "humidity":  { ".validate": "newData.isNumber() && newData.val() >= 0  && newData.val() <= 100" },
              "heatIndex": { ".validate": "newData.isNumber()" },
              "comfort":   { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 60" },
              "timestamp": { ".validate": "newData.isNumber() && newData.val() > 0" }
            }
          }
        },

        "weather": {
          ".write": true,
          ".validate": "newData.hasChildren(['temp', 'feelsLike', 'humidity', 'windSpeed', 'description'])",

          "temp":        { ".validate": "newData.isNumber()" },
          "feelsLike":   { ".validate": "newData.isNumber()" },
          "humidity":    { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100" },
          "windSpeed":   { ".validate": "newData.isNumber() && newData.val() >= 0" },
          "description": { ".validate": "newData.isString() && newData.val().length <= 100" }
        }
      }
    }
  }
}
