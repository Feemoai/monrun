# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── SECURITY: Jangan pernah commit file ini ──────────────────────
# Env files (berisi Firebase keys, API keys)
.env
.env.local
.env.*.local
.env.production

# Firebase service account (jika pakai Firebase Admin SDK)
*-service-account*.json
firebase-adminsdk*.json

# Seed script (berisi config Firebase hardcoded untuk testing)
scripts/seed-firebase.mjs

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
